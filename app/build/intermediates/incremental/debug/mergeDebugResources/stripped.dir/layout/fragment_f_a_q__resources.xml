<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/frameLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FAQ_Resources">

    <!-- Header background (Fixed at top) -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="0dp"
        android:layout_height="@dimen/header_height"
        android:background="@color/semi_transparent_black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/title_template"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:shadowColor="@color/black"
        android:shadowDx="@dimen/shadow_dx"
        android:shadowDy="@dimen/shadow_dy"
        android:shadowRadius="@dimen/shadow_radius"
        android:text="@string/u_plan_title"
        android:textColor="@color/brand_red"
        android:textSize="@dimen/text_size_display"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/header_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="@dimen/image_view_icon_width"
        android:layout_height="@dimen/image_view_icon_height"
        android:layout_marginStart="@dimen/spacing_medium"
        android:layout_marginTop="@dimen/spacing_medium"
        android:contentDescription="@string/university_logo_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ut_spartans_wordmark" />

    <WebView
        android:id="@+id/webView"
        android:layout_width="@dimen/webview_width"
        android:layout_height="@dimen/webview_height"
        android:layout_marginTop="@dimen/spacing_medium"
        android:layout_marginEnd="@dimen/spacing_xlarge"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Search Bar -->
    <EditText
        android:id="@+id/search_bar"
        android:layout_width="0dp"
        android:layout_height="@dimen/search_bar_height"
        android:layout_marginHorizontal="@dimen/spacing_xxlarge"
        android:layout_marginTop="@dimen/spacing_xlarge"
        android:background="@drawable/search_bar_background"
        android:hint="@string/search_hint"
        android:textColorHint="@color/text_color_hint"
        android:textColor="@color/medium_gray"
        android:paddingHorizontal="@dimen/spacing_xlarge"
        android:textSize="@dimen/text_size_body_1"
        android:importantForAutofill="no"
        android:inputType="text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header_bg" />

    <!-- Main Container for ScrollViews to allow weighting -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/search_bar">

        <!-- FAQ SECTION CONTAINER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/faq_title_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="@string/faq_title"
                android:textColor="@color/brand_red"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold" />

            <View
                android:id="@+id/faq_divider"
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:layout_marginHorizontal="@dimen/spacing_xxxlarge"
                android:layout_marginTop="@dimen/spacing_medium"
                android:background="@color/dark_gray_2" />

            <ScrollView
                android:id="@+id/faq_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="@dimen/spacing_medium"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_xxlarge"
                    android:paddingBottom="@dimen/spacing_xlarge">

                    <!-- FAQ Item 1 -->
                    <LinearLayout
                        android:id="@+id/faq_item_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:background="@drawable/faq_item_background"
                        android:orientation="vertical"
                        android:padding="@dimen/divider_height">
                        <LinearLayout
                            android:id="@+id/faq_header_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_large">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/faq_1_title"
                                android:textColor="@color/medium_gray"
                                android:textSize="@dimen/text_size_body_1"
                                android:textStyle="bold" />
                            <ImageView
                                android:id="@+id/faq_arrow_1"
                                android:layout_width="@dimen/arrow_icon_size"
                                android:layout_height="@dimen/arrow_icon_size"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="@string/expand_collapse_description"
                                app:tint="@color/off_white" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/faq_content_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/spacing_large"
                            android:paddingBottom="@dimen/spacing_large"
                            android:text="@string/faq_1_content"
                            android:textColor="@color/dark_gray"
                            android:textSize="@dimen/text_size_caption"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- FAQ Item 2 -->
                    <LinearLayout
                        android:id="@+id/faq_item_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:background="@drawable/faq_item_background"
                        android:orientation="vertical"
                        android:padding="@dimen/divider_height">
                        <LinearLayout
                            android:id="@+id/faq_header_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_large">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/faq_2_title"
                                android:textColor="@color/medium_gray"
                                android:textSize="@dimen/text_size_body_1"
                                android:textStyle="bold" />
                            <ImageView
                                android:id="@+id/faq_arrow_2"
                                android:layout_width="@dimen/arrow_icon_size"
                                android:layout_height="@dimen/arrow_icon_size"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="@string/expand_collapse_description"
                                app:tint="@color/off_white" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/faq_content_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/spacing_large"
                            android:paddingBottom="@dimen/spacing_large"
                            android:text="@string/faq_2_content"
                            android:textColor="@color/dark_gray"
                            android:textSize="@dimen/text_size_caption"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- FAQ Item 3 -->
                    <LinearLayout
                        android:id="@+id/faq_item_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:background="@drawable/faq_item_background"
                        android:orientation="vertical"
                        android:padding="@dimen/divider_height">
                        <LinearLayout
                            android:id="@+id/faq_header_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_large">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/faq_3_title"
                                android:textColor="@color/medium_gray"
                                android:textSize="@dimen/text_size_body_1"
                                android:textStyle="bold" />
                            <ImageView
                                android:id="@+id/faq_arrow_3"
                                android:layout_width="@dimen/arrow_icon_size"
                                android:layout_height="@dimen/arrow_icon_size"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="@string/expand_collapse_description"
                                app:tint="@color/off_white" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/faq_content_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/spacing_large"
                            android:paddingBottom="@dimen/spacing_large"
                            android:text="@string/faq_3_content"
                            android:textColor="@color/dark_gray"
                            android:textSize="@dimen/text_size_caption"
                            android:visibility="gone" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>

        <!-- Visual Separator -->
        <View
            android:id="@+id/section_separator"
            android:layout_width="match_parent"
            android:layout_height="@dimen/separator_height"
            android:background="@color/light_gray_2" />

        <!-- RESOURCES SECTION CONTAINER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/resources_title_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_large"
                android:text="@string/resources_title"
                android:textColor="@color/brand_red"
                android:textSize="@dimen/text_size_title"
                android:textStyle="bold" />

            <View
                android:id="@+id/resources_divider_line"
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:layout_marginHorizontal="@dimen/spacing_xxxlarge"
                android:layout_marginTop="@dimen/spacing_medium"
                android:background="@color/dark_gray_2" />

            <ScrollView
                android:id="@+id/res_scroll_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="@dimen/spacing_medium"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_xxlarge"
                    android:paddingBottom="@dimen/spacing_xxxlarge">

                    <!-- Resource Item 1 -->
                    <LinearLayout
                        android:id="@+id/res_item_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_medium"
                        android:background="@drawable/faq_item_background"
                        android:orientation="vertical"
                        android:padding="@dimen/divider_height">
                        <LinearLayout
                            android:id="@+id/res_header_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_large">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/resource_1_title"
                                android:textColor="@color/medium_gray"
                                android:textSize="@dimen/text_size_body_1"
                                android:textStyle="bold" />
                            <ImageView
                                android:id="@+id/res_arrow_1"
                                android:layout_width="@dimen/arrow_icon_size"
                                android:layout_height="@dimen/arrow_icon_size"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="@string/expand_collapse_description"
                                app:tint="@color/off_white" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/res_content_1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/spacing_large"
                            android:paddingBottom="@dimen/spacing_large"
                            android:text="@string/resource_1_content"
                            android:textColor="@color/dark_gray"
                            android:textSize="@dimen/text_size_caption"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Resource Item 2 -->
                    <LinearLayout
                        android:id="@+id/res_item_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:background="@drawable/faq_item_background"
                        android:orientation="vertical"
                        android:padding="@dimen/divider_height">
                        <LinearLayout
                            android:id="@+id/res_header_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_large">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/resource_2_title"
                                android:textColor="@color/medium_gray"
                                android:textSize="@dimen/text_size_body_1"
                                android:textStyle="bold" />
                            <ImageView
                                android:id="@+id/res_arrow_2"
                                android:layout_width="@dimen/arrow_icon_size"
                                android:layout_height="@dimen/arrow_icon_size"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="@string/expand_collapse_description"
                                app:tint="@color/off_white" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/res_content_2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/spacing_large"
                            android:paddingBottom="@dimen/spacing_large"
                            android:text="@string/resource_2_content"
                            android:textColor="@color/dark_gray"
                            android:textSize="@dimen/text_size_caption"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Resource Item 3 -->
                    <LinearLayout
                        android:id="@+id/res_item_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_large"
                        android:background="@drawable/faq_item_background"
                        android:orientation="vertical"
                        android:padding="@dimen/divider_height">
                        <LinearLayout
                            android:id="@+id/res_header_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:orientation="horizontal"
                            android:padding="@dimen/spacing_large">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/resource_3_title"
                                android:textColor="@color/medium_gray"
                                android:textSize="@dimen/text_size_body_1"
                                android:textStyle="bold" />
                            <ImageView
                                android:id="@+id/res_arrow_3"
                                android:layout_width="@dimen/arrow_icon_size"
                                android:layout_height="@dimen/arrow_icon_size"
                                android:src="@android:drawable/arrow_down_float"
                                android:contentDescription="@string/expand_collapse_description"
                                app:tint="@color/off_white" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/res_content_3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/spacing_large"
                            android:paddingBottom="@dimen/spacing_large"
                            android:text="@string/resource_3_content"
                            android:textColor="@color/dark_gray"
                            android:textSize="@dimen/text_size_caption"
                            android:visibility="gone" />
                    </LinearLayout>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
