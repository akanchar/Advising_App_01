<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Template Skeleton -->
    <include layout="@layout/skeleton" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header_bg"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/transferTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Transfer Information"
                android:textAlignment="center"
                android:textColor="#d22031"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Conditional Trigger: Transfer Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transfer Type"
                android:textStyle="bold"
                android:textColor="@color/medium_gray" />

            <RadioGroup
                android:id="@+id/rg_transfer_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb_domestic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Domestic"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rb_international"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="International" />
            </RadioGroup>

            <!-- Dynamic Section: Domestic -->
            <LinearLayout
                android:id="@+id/domestic_info_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="State of Previous School"
                    android:textStyle="bold"
                    android:textColor="@color/medium_gray" />
                <Spinner
                    android:id="@+id/spinner_state"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:background="@android:drawable/btn_dropdown" />
            </LinearLayout>

            <!-- Dynamic Section: International (Conditional) -->
            <LinearLayout
                android:id="@+id/international_info_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Country of Origin"
                    android:textStyle="bold"
                    android:textColor="@color/medium_gray" />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:hint="e.g. Canada, UK"
                    android:inputType="text" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visa Type"
                    android:textStyle="bold"
                    android:textColor="@color/medium_gray" />
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="16dp"
                    android:hint="e.g. F-1, J-1"
                    android:inputType="text" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Previous School Name"
                android:textStyle="bold"
                android:textColor="@color/medium_gray" />

            <EditText
                android:id="@+id/edit_previous_school"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:hint="Enter school name"
                android:inputType="text" />

            <Button
                android:id="@+id/btn_save_transfer_info"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="#d22031"
                android:text="Save Transfer Info"
                android:textColor="@color/white" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>