<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".ProgressAreaFragment">

    <!-- Template Skeleton -->
    <include layout="@layout/skeleton" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header_bg"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_bg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Academic Progress"
                android:textAlignment="center"
                android:textColor="#d22031"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Conditional Trigger: Plan Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Graduation Plan:"
                android:textStyle="bold"
                android:textColor="#555555"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rg_plan_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb_standard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Standard"
                    android:checked="true"/>
                <RadioButton
                    android:id="@+id/rb_accelerated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Accelerated" />
            </RadioGroup>

            <!-- DYNAMIC ALERT: Only for Accelerated Plan -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/accelerated_alert_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF3E0"
                app:strokeColor="#FFB74D"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/stat_sys_warning"
                        app:tint="#E65100" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Accelerated plan requires 18 credits per semester and summer courses."
                        android:textColor="#E65100"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GPA Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cumulative GPA"
                        android:textColor="#666666"
                        android:textSize="16sp" />
                    <TextView
                        android:id="@+id/tv_gpa_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3.85"
                        android:textColor="#d22031"
                        android:textSize="48sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Progress Summary (Dynamic Text) -->
            <TextView
                android:id="@+id/tv_status_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#F8F8F8"
                android:padding="12dp"
                android:text="Status: On track for Spring 2026 graduation."
                android:textAlignment="center"
                android:textStyle="italic" />

            <!-- Major Progress Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Major: Mathematics"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#333333"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_major"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:trackThickness="12dp"
                app:trackCornerRadius="6dp"
                android:progress="75"
                app:indicatorColor="#d22031"
                app:trackColor="#EEEEEE"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_major_credits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="75% Complete (45 / 60 Credits)"
                android:textAlignment="viewEnd"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/btn_change_profile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:backgroundTint="#d22031"
                android:text="Change Profile Information"
                android:textColor="#FFFFFF"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>